{
    "name": "netbrothers-gmbh/typo3-base-template",
    "type": "typo3-cms-extension",
    "description": "TYPO3 Base Template based on Bootstrap Package by legendary Benjamin Kott",
    "keywords": ["TYPO3 CMS"],
    "homepage": "https://netbrothers.de/",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Thilo Ratnaweera",
            "email": "thilo.ratnaweera@netbrothers.de",
            "homepage": "https://netbrothers.de/"
        }
    ],
    "autoload": {
        "psr-4": {
            "NetBrothers\\TYPO3BaseTemplate\\": "Classes"
        }
    },
    "require": {
        "php": ">=8.2",
        "b13/container": "^3",
        "typo3/cms-backend": "^13",
        "typo3/cms-core": "^13",
        "typo3/cms-frontend": "^13",
        "typo3/cms-install": "^13"
    },
    "require-dev": {
        "phpstan/phpstan": "^2"
    },
    "config": {
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true
        },
        "sort-packages": true
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "nb_basetemplate"
        }
    }
}
