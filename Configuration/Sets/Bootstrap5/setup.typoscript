
# See https://docs.typo3.org/m/typo3/reference-typoscript/13.4/en-us/Conditions/Index.html#condition-functions-in-frontend-context-function-site
# See https://docs.typo3.org/m/typo3/reference-coreapi/13.4/en-us/ApiOverview/SiteHandling/UseSiteInConditions.html

page = PAGE

[site("configuration")["settings"]["plugin"]["tx_nb_basetemplate"]["disableBootstrapCss"] != 1]
page {
    includeCSSLibs {
        bootstrap_css = EXT:nb_basetemplate/Resources/Public/Css/theme.css
    }
}
[END]

[site("configuration")["settings"]["plugin"]["tx_nb_basetemplate"]["disableBootstrapBundleJs"] != 1]
page {
    includeJSFooterlibs {
        bootstrap_bundle_js = EXT:nb_basetemplate/Resources/Public/JavaScript/bootstrap.bundle.min.js
    }
}
[END]
