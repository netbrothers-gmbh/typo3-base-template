# EXTENSIONS
# Manual inclusion to keep control over loading order
[extension.isLoaded('form') == 1]
    @import 'EXT:nb_basetemplate/Configuration/TypoScript/Extension/Form/setup.typoscript'
[end]

[extension.isLoaded('seo') == 1]
    @import 'EXT:nb_basetemplate/Configuration/TypoScript/Extension/Seo/setup.typoscript'
[end]

[extension.isLoaded('container') == 1]
    @import 'EXT:nb_basetemplate/Configuration/TypoScript/Extension/Container/setup.typoscript'
[end]
