tt_content.tab >
# CTYPE: TYPO3 BASE TEMPLATE TAB
tt_content.tab =< lib.contentElement
tt_content.tab {
    templateName = Tab
    dataProcessing {
        10 = NetBrothers\TYPO3BaseTemplate\DataProcessing\FlexFormProcessor
        20 = TYPO3\CMS\Frontend\DataProcessing\DatabaseQueryProcessor
        20 {
            table = tx_nbbasetemplate_tab_item
            pidInList.field = pid
            where {
                data = field:uid
                intval = 1
                wrap = tt_content=|
            }
            orderBy = sorting
            dataProcessing {
                10 = TYPO3\CMS\Frontend\DataProcessing\FilesProcessor
                10 {
                    references.fieldName = media
                }
            }
        }
    }
}


lib.contentElement.settings.responsiveimages.contentelements {
    tab {
        left {
            multiplier {
                default = 0.5
                xlarge = 0.5
                large = 0.5
                medium = 0.5
            }
            gutters {
                default = 16
                xlarge = 16
                large = 16
                medium = 16
            }
        }
        right {
            multiplier {
                default = 0.5
                xlarge = 0.5
                large = 0.5
                medium = 0.5
            }
            gutters {
                default = 16
                xlarge = 16
                large = 16
                medium = 16
            }
        }
    }
}
