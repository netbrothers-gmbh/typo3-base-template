page {
    includeCSS {
        theme = EXT:nb_basetemplate/Resources/Public/Css/theme.css
        if {
            isTrue = {$plugin.nb_basetemplate.loadBootstrap}
        }
    }
    includeJSFooterlibs {
        bootstrap = EXT:nb_basetemplate/Resources/Public/JavaScript/bootstrap.bundle.min.js
    }
}
