
[{$plugin.tx_nb_basetemplate.disableBootstrapCss} != 1]
page {
    includeCSSLibs {
        bootstrap_css = EXT:nb_basetemplate/Resources/Public/Css/theme.css
    }
}
[END]

[{$plugin.tx_nb_basetemplate.disableBootstrapBundleJs} != 1]
page {
    includeJSFooterlibs {
        bootstrap_bundle_js = EXT:nb_basetemplate/Resources/Public/JavaScript/bootstrap.bundle.min.js
    }
}
[END]
